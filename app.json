{
  "expo": {
    "name": "BlastMyCV",
    "slug": "blastmycv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "blastmycv",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#1A56DB"
    },
    "updates": {
      "enabled": false
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.blastmycv.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow BlastMyCV to access your photos to upload your CV.",
        "NSCameraUsageDescription": "Allow BlastMyCV to use your camera."
      }
    },
    "android": {
      "package": "com.blastmycv.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.jpg",
        "backgroundColor": "#1A56DB"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.jpg"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://blastmycv.com"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "aaf1a3b5-3f9b-4bda-a622-19c2f38c813f"
      }
    }
  }
}
